# ==========================================
# MUSEUM BAHARI NGERA SHELLS
# Cache Control & Performance
# ==========================================

# Enable Compression (untuk performa)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json
</IfModule>

# Cache Control untuk Development
<IfModule mod_headers.c>
    # HTML - No cache (selalu ambil versi terbaru)
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    
    # CSS & JS - Cache 1 jam (untuk development)
    # Ganti ke "max-age=31536000" saat production stabil
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "max-age=3600, must-revalidate"
    </FilesMatch>
    
    # Images - Cache 1 minggu
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "max-age=604800"
    </FilesMatch>
</IfModule>

# Enable CORS untuk Firebase
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
</IfModule>

# Prevent directory listing
Options -Indexes

# Custom error pages (opsional)
ErrorDocument 404 /index.html